{
	"info": {
		"name": "Buddy Script Server — Auth",
		"description": "Auth + feed API tests. Run top-to-bottom with the Collection Runner: registration uses a fresh timestamped email each run, the JWT flows automatically through Postman's cookie jar (httpOnly cookie), and the post-logout requests verify access is revoked.\n\nSet `baseUrl` if the server is not on http://localhost:5000.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000"
		},
		{
			"key": "email",
			"value": ""
		},
		{
			"key": "password",
			"value": "TestPassword123"
		},
		{
			"key": "userId",
			"value": ""
		},
		{
			"key": "postId",
			"value": ""
		},
		{
			"key": "privatePostId",
			"value": ""
		},
		{
			"key": "commentId",
			"value": ""
		},
		{
			"key": "replyId",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Health",
			"request": {
				"method": "GET",
				"url": "{{baseUrl}}/health"
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('status is 200', () => pm.response.to.have.status(200));",
							"pm.test('reports ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
						],
						"type": "text/javascript"
					}
				}
			]
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Fresh email every run so re-runs don't hit the unique constraint",
									"pm.collectionVariables.set('email', `user_${Date.now()}@example.com`);"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('status is 201', () => pm.response.to.have.status(201));",
									"pm.test('returns the user without password', () => {",
									"  const { user } = pm.response.json();",
									"  pm.expect(user.email).to.eql(pm.collectionVariables.get('email'));",
									"  pm.expect(user).to.have.keys(['id', 'firstName', 'lastName', 'email', 'avatarUrl', 'createdAt']);",
									"  pm.collectionVariables.set('userId', user.id);",
									"});",
									"pm.test('sets httpOnly auth cookie', () => {",
									"  const setCookie = pm.response.headers.get('Set-Cookie');",
									"  pm.expect(setCookie).to.include('token=');",
									"  pm.expect(setCookie).to.include('HttpOnly');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
						},
						"url": "{{baseUrl}}/api/auth/register"
					}
				},
				{
					"name": "Register — Duplicate Email",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('status is 409', () => pm.response.to.have.status(409));",
									"pm.test('explains the conflict', () => pm.expect(pm.response.json().error).to.include('already exists'));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
						},
						"url": "{{baseUrl}}/api/auth/register"
					}
				},
				{
					"name": "Register — Invalid Body",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('status is 400', () => pm.response.to.have.status(400));",
									"pm.test('returns per-field details', () => {",
									"  const { error, details } = pm.response.json();",
									"  pm.expect(error).to.eql('Validation failed');",
									"  const fields = details.map(d => d.field);",
									"  pm.expect(fields).to.include.members(['firstName', 'lastName', 'email', 'password']);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"\",\n  \"email\": \"not-an-email\",\n  \"password\": \"short\"\n}"
						},
						"url": "{{baseUrl}}/api/auth/register"
					}
				},
				{
					"name": "Login — Wrong Password",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('status is 401', () => pm.response.to.have.status(401));",
									"pm.test('generic message (no user enumeration)', () => pm.expect(pm.response.json().error).to.eql('Invalid email or password'));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"WrongPassword999\"\n}"
						},
						"url": "{{baseUrl}}/api/auth/login"
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('status is 200', () => pm.response.to.have.status(200));",
									"pm.test('returns the user', () => pm.expect(pm.response.json().user.email).to.eql(pm.collectionVariables.get('email')));",
									"pm.test('sets httpOnly auth cookie', () => {",
									"  const setCookie = pm.response.headers.get('Set-Cookie');",
									"  pm.expect(setCookie).to.include('token=');",
									"  pm.expect(setCookie).to.include('HttpOnly');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
						},
						"url": "{{baseUrl}}/api/auth/login"
					}
				},
				{
					"name": "Me",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('status is 200', () => pm.response.to.have.status(200));",
									"pm.test('returns the logged-in user', () => pm.expect(pm.response.json().user.email).to.eql(pm.collectionVariables.get('email')));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/auth/me"
					}
				}
			]
		},
