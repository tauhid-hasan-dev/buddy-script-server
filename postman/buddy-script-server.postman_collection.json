							"listen": "test",
							"script": {
								"exec": [
									"pm.test('status is 200', () => pm.response.to.have.status(200));",
									"pm.test('returns users with pagination meta', () => {",
									"  const { users, meta } = pm.response.json();",
									"  pm.expect(users).to.be.an('array').that.is.not.empty;",
									"  pm.expect(users.length).to.be.at.most(10);",
									"  pm.expect(meta).to.include.keys(['page', 'limit', 'total', 'totalPages']);",
									"});",
									"pm.test('profiles include email but never the password hash', () => {",
									"  const { users } = pm.response.json();",
									"  users.forEach(u => pm.expect(u).to.have.property('email'));",
									"  pm.expect(pm.response.text()).to.not.include('Hash');",
									"});"
								],
								"type": "text/javascript"
							}
						}
