{
  "info": {
    "name": "Buddy Script Server — Auth",
    "description": "Auth + feed API tests. Run top-to-bottom with the Collection Runner: registration uses a fresh timestamped email each run, the JWT flows automatically through Postman's cookie jar (httpOnly cookie), and the post-logout requests verify access is revoked.\n\nSet `baseUrl` if the server is not on http://localhost:5000.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "email", "value": "" },
    { "key": "password", "value": "TestPassword123" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "pm.test('reports ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Fresh email every run so re-runs don't hit the unique constraint",
                  "pm.collectionVariables.set('email', `user_${Date.now()}@example.com`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('returns the user without password', () => {",
                  "  const { user } = pm.response.json();",
                  "  pm.expect(user.email).to.eql(pm.collectionVariables.get('email'));",
                  "  pm.expect(user).to.have.keys(['id', 'firstName', 'lastName', 'email', 'createdAt']);",
                  "  pm.collectionVariables.set('userId', user.id);",
                  "});",
                  "pm.test('sets httpOnly auth cookie', () => {",
                  "  const setCookie = pm.response.headers.get('Set-Cookie');",
                  "  pm.expect(setCookie).to.include('token=');",
                  "  pm.expect(setCookie).to.include('HttpOnly');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Register — Duplicate Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 409', () => pm.response.to.have.status(409));",
                  "pm.test('explains the conflict', () => pm.expect(pm.response.json().error).to.include('already exists'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Register — Invalid Body",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('returns per-field details', () => {",
                  "  const { error, details } = pm.response.json();",
                  "  pm.expect(error).to.eql('Validation failed');",
                  "  const fields = details.map(d => d.field);",
                  "  pm.expect(fields).to.include.members(['firstName', 'lastName', 'email', 'password']);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"\",\n  \"email\": \"not-an-email\",\n  \"password\": \"short\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login — Wrong Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 401', () => pm.response.to.have.status(401));",
                  "pm.test('generic message (no user enumeration)', () => pm.expect(pm.response.json().error).to.eql('Invalid email or password'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"WrongPassword999\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns the user', () => pm.expect(pm.response.json().user.email).to.eql(pm.collectionVariables.get('email')));",
                  "pm.test('sets httpOnly auth cookie', () => {",
                  "  const setCookie = pm.response.headers.get('Set-Cookie');",
                  "  pm.expect(setCookie).to.include('token=');",
                  "  pm.expect(setCookie).to.include('HttpOnly');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns the logged-in user', () => pm.expect(pm.response.json().user.email).to.eql(pm.collectionVariables.get('email')));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Feed",
      "item": [
        {
          "name": "Get Feed",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns posts + nextCursor', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.posts).to.be.an('array');",
                  "  pm.expect(body).to.have.property('nextCursor');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/feed?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "feed"],
              "query": [
                { "key": "limit", "value": "20" },
                { "key": "cursor", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Feed — Invalid Cursor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('flags the cursor field', () => {",
                  "  const { details } = pm.response.json();",
                  "  pm.expect(details.map(d => d.field)).to.include('cursor');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/feed?cursor=not-a-number",
              "host": ["{{baseUrl}}"],
              "path": ["api", "feed"],
              "query": [{ "key": "cursor", "value": "not-a-number" }]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns users with pagination meta', () => {",
                  "  const { users, meta } = pm.response.json();",
                  "  pm.expect(users).to.be.an('array').that.is.not.empty;",
                  "  pm.expect(users.length).to.be.at.most(10);",
                  "  pm.expect(meta).to.include.keys(['page', 'limit', 'total', 'totalPages']);",
                  "});",
                  "pm.test('profiles do not expose emails', () => {",
                  "  const { users } = pm.response.json();",
                  "  users.forEach(u => pm.expect(u).to.not.have.property('email'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "List Users — Limit Above Cap",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('flags the limit field', () => {",
                  "  const { details } = pm.response.json();",
                  "  pm.expect(details.map(d => d.field)).to.include('limit');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users?limit=999",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"],
              "query": [{ "key": "limit", "value": "999" }]
            }
          }
        },
        {
          "name": "Get User Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns the public profile without email', () => {",
                  "  const { user } = pm.response.json();",
                  "  pm.expect(user.id).to.eql(pm.collectionVariables.get('userId'));",
                  "  pm.expect(user).to.have.keys(['id', 'firstName', 'lastName', 'createdAt']);",
                  "  pm.expect(user).to.not.have.property('email');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Get User — Invalid Id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('explains the error', () => pm.expect(pm.response.json().error).to.eql('Invalid user id'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/not-a-uuid"
          }
        },
        {
          "name": "Get User — Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 404', () => pm.response.to.have.status(404));",
                  "pm.test('explains the error', () => pm.expect(pm.response.json().error).to.eql('User not found'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/00000000-0000-4000-8000-000000000000"
          }
        },
        {
          "name": "Update My Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns the updated profile', () => {",
                  "  const { user } = pm.response.json();",
                  "  pm.expect(user.firstName).to.eql('Updated');",
                  "  pm.expect(user.lastName).to.eql('Name');",
                  "  pm.expect(user.id).to.eql(pm.collectionVariables.get('userId'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Updated\",\n  \"lastName\": \"Name\"\n}"
            },
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Update My Profile — Empty Body",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 400', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Update My Profile — Unknown Field Rejected",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 400 (email cannot be updated here)', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Sneaky\",\n  \"email\": \"hijacked@example.com\"\n}"
            },
            "url": "{{baseUrl}}/api/users/me"
          }
        }
      ]
    },
    {
      "name": "Logout",
      "item": [
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('clears the auth cookie', () => {",
                  "  const setCookie = pm.response.headers.get('Set-Cookie');",
                  "  pm.expect(setCookie).to.include('token=;');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout"
          }
        },
        {
          "name": "Me — After Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 401', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "Feed — After Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 401', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/feed"
          }
        }
      ]
    }
  ]
}
