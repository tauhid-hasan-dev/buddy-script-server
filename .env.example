# Server
PORT=5000
NODE_ENV=development

# Frontend origin allowed by CORS (cookies require an explicit origin, not *)
CLIENT_URL=http://localhost:3000

# Supabase Postgres — app traffic via transaction pooler, migrations direct
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

# Supabase Storage (post images)
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=post-images

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Redis (optional) — when set, the hot feed page is cached and rate limits are
# shared across API replicas. Unset → in-process fallback (single instance).
# REDIS_URL="redis://localhost:6379"
