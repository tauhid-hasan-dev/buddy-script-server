# Server
PORT=5000
NODE_ENV=development

# Frontend origin allowed by CORS (cookies require an explicit origin, not *)
CLIENT_URL=http://localhost:5173

# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/buddy_script?schema=public"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d
